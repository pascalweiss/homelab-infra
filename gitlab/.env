# Base directory for GitLab persistent storage
GITLAB_BASE=/var/lib/gitlab

# Configuration files
GITLAB_CONFIG=${GITLAB_BASE}/config

# Logs
GITLAB_LOGS=${GITLAB_BASE}/logs

# Application data
GITLAB_DATA=${GITLAB_BASE}/data

# Redis data
REDIS_DATA=${GITLAB_BASE}/redis

# Hostname and ports
GITLAB_HOSTNAME=gitlab.local
GITLAB_HTTP_PORT=8080
GITLAB_HTTPS_PORT=8443
GITLAB_SSH_PORT=2222